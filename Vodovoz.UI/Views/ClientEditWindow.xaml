<Window x:Class="Vodovoz.UI.Views.ClientEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:Vodovoz.UI.Views"
        Title="{Binding Title}" 
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Название Label -->
            <RowDefinition Height="Auto"/>
            <!-- 1: Название TextBox -->
            <RowDefinition Height="Auto"/>
            <!-- 2: ИНН Label -->
            <RowDefinition Height="Auto"/>
            <!-- 3: ИНН TextBox -->
            <RowDefinition Height="Auto"/>
            <!-- 4: Куратор Label -->
            <RowDefinition Height="Auto"/>
            <!-- 5: Куратор TextBox -->
            <RowDefinition Height="*"/>
            <!-- 6: Пустое пространство -->
            <RowDefinition Height="Auto"/>
            <!-- 7: Кнопки -->
        </Grid.RowDefinitions>

        <TextBlock Text="Название *" Grid.Row="0" Margin="0,0,0,5"/>
        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
         Grid.Row="1" Margin="0,0,0,15"/>

        <TextBlock Text="ИНН *" Grid.Row="2" Margin="0,0,0,5"/>
        <TextBox Text="{Binding Inn, UpdateSourceTrigger=PropertyChanged}" 
         Grid.Row="3" Margin="0,0,0,15"/>

        <TextBlock Text="Куратор" Grid.Row="4" Margin="0,0,0,5"/>
        <ComboBox ItemsSource="{Binding Employees}"
          SelectedValue="{Binding CuratorId}"
          SelectedValuePath="Id"
          DisplayMemberPath="Surname"
          Grid.Row="5" 
          Margin="0,0,0,15"/>

        <StackPanel Orientation="Horizontal" 
            HorizontalAlignment="Right" 
            Grid.Row="7">
            <Button Content="Сохранить" 
                Command="{Binding SaveCommand}" 
                Width="100" 
                Margin="0,0,10,0" 
                IsDefault="True"/>
            <Button Content="Отмена" 
                Command="{Binding CancelCommand}" 
                Width="100" 
                IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
