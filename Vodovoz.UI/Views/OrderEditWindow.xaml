<Window x:Class="Vodovoz.UI.Views.OrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vodovoz.UI.Views"
        mc:Ignorable="d"
        Title="{Binding Title}" 
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Дата Label -->
            <RowDefinition Height="Auto"/>
            <!-- 1: Дата TextBox -->
            <RowDefinition Height="Auto"/>
            <!-- 2: Сумма Label -->
            <RowDefinition Height="Auto"/>
            <!-- 3: Сумма TextBox -->
            <RowDefinition Height="Auto"/>
            <!-- 4: Сотрудник Label -->
            <RowDefinition Height="Auto"/>
            <!-- 5: Сотрудник TextBox -->
            <RowDefinition Height="Auto"/>
            <!-- 6: Клиент Label -->
            <RowDefinition Height="Auto"/>
            <!-- 7: Клиент ComboBox -->
            <RowDefinition Height="Auto"/>
            <!-- 10: Пустое пространство -->
            <RowDefinition Height="Auto"/>
            <!-- 11: Кнопки -->
        </Grid.RowDefinitions>

        <TextBlock Text="Дата заказа *" Grid.Row="0" Margin="0,0,0,5"/>
        <DatePicker SelectedDate="{Binding Date}" 
            Grid.Row="1" Margin="0,0,0,15"/>

        <TextBlock Text="Сумма заказа *" Grid.Row="2" Margin="0,0,0,5"/>
        <TextBox Text="{Binding Sum, UpdateSourceTrigger=PropertyChanged}" 
            Grid.Row="3" Margin="0,0,0,15"/>

        <TextBlock Text="Сотрудник" Grid.Row="4" Margin="0,0,0,5"/>
        <ComboBox ItemsSource="{Binding Employees}"
            SelectedValue="{Binding EmployeeId}"
            SelectedValuePath="Id"
            DisplayMemberPath="Surname"
            Grid.Row="5" 
            Margin="0,0,0,15"/>

        <TextBlock Text="Клиент" Grid.Row="6" Margin="0,0,0,5"/>
        <ComboBox ItemsSource="{Binding Clients}"
          SelectedValue="{Binding ClientId}"
          SelectedValuePath="Id"
          DisplayMemberPath="Name"
          Grid.Row="7" 
          Margin="0,0,0,15"/>

        <StackPanel Orientation="Horizontal" 
            HorizontalAlignment="Right" 
            Grid.Row="11">
            <Button Content="Сохранить" 
            Command="{Binding SaveCommand}" 
            Width="100" 
            Margin="0,0,10,0" 
            IsDefault="True"/>
            <Button Content="Отмена" 
            Command="{Binding CancelCommand}" 
            Width="100" 
            IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
